<UserControl x:Class="LinkFormatter.Views.FilesListView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
    <StackPanel Spacing="8">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Downloaded Files"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}" />
        <Button Grid.Column="1"
                Content="Refresh"
                Command="{Binding RefreshCommand}"
                Background="{StaticResource BackgroundBrush}" />
      </Grid>

      <ListBox ItemsSource="{Binding Files}" Background="{StaticResource BackgroundBrush}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" />
              <Button Content="Open"
                      Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>
  </Border>
</UserControl>

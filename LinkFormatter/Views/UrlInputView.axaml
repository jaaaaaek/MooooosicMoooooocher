<UserControl x:Class="LinkFormatter.Views.UrlInputView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:LinkFormatter.Models">
  <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="12">
    <StackPanel Spacing="8">
      <TextBlock Text="Add a SoundCloud URL"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextBrush}" />

      <TextBox Text="{Binding UrlText}"
               Watermark="https://soundcloud.com/artist/track"
               Background="{StaticResource BackgroundBrush}" />

      <StackPanel Orientation="Horizontal" Spacing="10">
        <ComboBox Width="140"
                  SelectedValue="{Binding SelectedFormat}"
                  SelectedValuePath="Tag"
                  Background="{StaticResource BackgroundBrush}">
          <ComboBoxItem Content="MP3" Tag="{x:Static models:AudioFormat.MP3}" />
          <ComboBoxItem Content="WAV" Tag="{x:Static models:AudioFormat.WAV}" />
        </ComboBox>
        <Button Content="Add"
                Command="{Binding AddUrlCommand}"
                Background="{StaticResource ClaudeOrangeBrush}"
                Foreground="White" />
      </StackPanel>

      <TextBlock Text="{Binding ValidationMessage}"
                 Foreground="{StaticResource ErrorBrush}"
                 IsVisible="{Binding HasError}" />
    </StackPanel>
  </Border>
</UserControl>
